<UserControl
    x:Class="Simargl.Embedded.Tunings.TuningsEditor.UI.Explorer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:core="clr-namespace:Simargl.Embedded.Tunings.TuningsEditor.Core"
    xmlns:ui="clr-namespace:Simargl.Embedded.Tunings.TuningsEditor.UI"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800"
    d:DataContext="{d:DesignInstance Type=core:Heart}">
    <TreeView ItemsSource="{Binding Project.RootNode.Nodes}" SelectedItemChanged="TreeView_SelectedItemChanged">
        <TreeView.ItemTemplate>
            <HierarchicalDataTemplate ItemsSource="{Binding Path=Nodes}">
                <ui:NodeItem/>
            </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</UserControl>
