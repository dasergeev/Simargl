<UserControl
    x:Class="Simargl.Embedded.Tunings.TuningsEditor.UI.MainControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:ui="clr-namespace:Simargl.Embedded.Tunings.TuningsEditor.UI"
    xmlns:core="clr-namespace:Simargl.Embedded.Tunings.TuningsEditor.Core"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    d:DataContext="{d:DesignInstance Type=core:Heart}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Row="1" Grid.RowSpan="2" Width="5" Background="Transparent"/>
        <GridSplitter Grid.Row="2" Grid.Column="1" Height="5" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
        <ui:Explorer Grid.Row="1" Grid.RowSpan="2" Margin="0,0,5,0" IsEnabled="{Binding IsEditEnabled}"/>
        <ui:Workspace Grid.Row="1" Grid.Column="1" IsEnabled="{Binding IsEditEnabled}"/>
        <ui:LogView Grid.Row="2" Grid.Column="1" Margin="0,5,0,0"/>
        <ToolBar ToolBarTray.IsLocked="True" Grid.ColumnSpan="2">
            <Button Command="{Binding NewProjectCommand}">
                <Image Source="/Images/Data/New.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Создать" FontWeight="Bold"/>
                        <TextBlock Text="Создать новый проект">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button Command="{Binding OpenProjectCommand}">
                <Image Source="/Images/Data/Open.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Открыть" FontWeight="Bold"/>
                        <TextBlock Text="Открыть существующий проект">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button Command="{Binding SaveProjectCommand}">
                <Image Source="/Images/Data/Save.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Сохранить" FontWeight="Bold"/>
                        <TextBlock Text="Сохранить проект">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button Command="{Binding SaveAsProjectCommand}">
                <Image Source="/Images/Data/SaveAs.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Сохранить как" FontWeight="Bold"/>
                        <TextBlock Text="Сохранить проект с указанием пути к файлу">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Separator/>
            <Button Command="{Binding CheckCommand}">
                <Image Source="/Images/Data/Check.ico" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Проверить" FontWeight="Bold"/>
                        <TextBlock Text="Выполнить проверку данных">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button Command="{Binding CppCommand}">
                <Image Source="/Images/Data/Cpp.ico" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="C++" FontWeight="Bold"/>
                        <TextBlock Text="Создать файл C++">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button Command="{Binding CSharpCommand}">
                <Image Source="/Images/Data/CSharp.ico" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="C#" FontWeight="Bold"/>
                        <TextBlock Text="Создать файл C#">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Separator/>
            <Button Command="{Binding StartCommand}">
                <Image Source="/Images/Data/Start.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Запуск" FontWeight="Bold"/>
                        <TextBlock Text="Запустить работу">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button Command="{Binding StopCommand}">
                <Image Source="/Images/Data/Stop.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Остановка" FontWeight="Bold"/>
                        <TextBlock Text="Остановить работу">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
        </ToolBar>
    </Grid>
</UserControl>
