<UserControl
    x:Class="Simargl.Engineering.Utilities.CertificateSheet.UI.MainControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Simargl.Engineering.Utilities.CertificateSheet.UI"
    xmlns:cs="clr-namespace:Simargl.Engineering.Utilities.CertificateSheet"
    d:DataContext="{d:DesignInstance Type=cs:Heart}"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <ToolBar ToolBarTray.IsLocked="True">
            <Button IsEnabled="{Binding StartButtonIsEnabled}" Click="StartButton_Click" >
                <Image Source="/Images/Start.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Запуск" FontWeight="Bold"/>
                        <TextBlock Text="Запустить работу.">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
            <Button IsEnabled="{Binding StopButtonIsEnabled}" Click="StopButton_Click" >
                <Image Source="/Images/Stop.png" Width="16" Height="16" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Остановить" FontWeight="Bold"/>
                        <TextBlock Text="Остановить работу.">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
        </ToolBar>
        <ListView Grid.Row="1" ItemsSource="{Binding Certificates}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <local:CertificateView/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ProgressBar Grid.Row="2" Value="{Binding Progress}" Height="5"/>
    </Grid>
</UserControl>
