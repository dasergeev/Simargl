<ui:BaseControl
    x:Class="Simargl.Detecting.Bearing.Simulator.UI.MainControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:ui="clr-namespace:Simargl.Detecting.Bearing.Simulator.UI"
    xmlns:common="clr-namespace:Simargl.Detecting.Bearing.Simulator.UI.Common"
    xmlns:local="clr-namespace:Simargl.Detecting.Bearing.Simulator.UI"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.RowSpan="3" Width="8" HorizontalAlignment="Right" Background="Transparent"/>
        <GridSplitter Height="5" VerticalAlignment="Bottom" Background="Transparent"/>
        <GridSplitter Grid.Column="1" Height="5" Grid.Row="2" VerticalAlignment="Top" Background="Transparent"/>
        <common:LogView Margin="0,5,0,0" Grid.Row="2" Grid.Column="1"/>
        <common:DataSourceView Margin="0,0,0,5"/>
        <common:SignalView Grid.RowSpan="2" Grid.Row="1"/>
    </Grid>
</ui:BaseControl>
