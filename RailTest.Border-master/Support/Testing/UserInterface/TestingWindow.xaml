<Window x:Class="RailTest.Border.Support.Testing.UserInterface.TestingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RailTest.Border.Support.Testing.UserInterface"
        mc:Ignorable="d"
        Title="TestingWindow" Height="450" Width="800">
    <Grid>
        <RichTextBox x:Name="_RichTextBox" Margin="10,35,10,10">
            <FlowDocument>
                <Paragraph x:Name="_Paragraph">
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <Button x:Name="_TestButton" Content="Test" HorizontalAlignment="Left" VerticalAlignment="Top" Width="75" Margin="10,10,0,0" Click="TestButton_Click"/>

    </Grid>
</Window>
