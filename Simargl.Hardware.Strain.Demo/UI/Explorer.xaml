<ui:Control
    x:Class="Simargl.Hardware.Strain.Demo.UI.Explorer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    xmlns:ui="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <Binding Path="Heart" RelativeSource="{RelativeSource Self}" />
    </UserControl.DataContext>
    <TreeView x:Name="_TreeView" ItemsSource="{Binding Path=RootNode.Nodes}" SelectedItemChanged="TreeView_SelectedItemChanged">
        <TreeView.ItemTemplate>
            <HierarchicalDataTemplate ItemsSource="{Binding Path=Nodes}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{Binding Image}" Width="16" Height="16" Margin="2" />
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</ui:Control>
