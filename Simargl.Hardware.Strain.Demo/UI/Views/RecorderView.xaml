<ui:NodeView
    x:Class="Simargl.Hardware.Strain.Demo.UI.Views.RecorderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Simargl.Hardware.Strain.Demo.UI.Views"
    xmlns:ui="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    xmlns:nodes="clr-namespace:Simargl.Hardware.Strain.Demo.Nodes"
    d:DataContext="{d:DesignInstance Type=nodes:RecorderNode}"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Column="1" HorizontalAlignment="Left" Width="5" Background="Transparent"/>
        <WindowsFormsHost x:Name="_Host" />
        <ListView ItemsSource="{Binding Signals}" Grid.Column="1" Margin="5,0,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox IsChecked="{Binding IsChecked}" />
                        <Image Grid.Column="1" Source="{Binding ColorImage}" Width="16" Height="16" Margin="2"/>
                        <Image Grid.Column="2" Source="{Binding Image}" Width="16" Height="16" Margin="2"/>
                        <TextBlock Grid.Column="3" Text="{Binding Name}" VerticalAlignment="Center"/>
                        <!--<TextBlock Grid.Column="1" Text="{Binding Name}" TextWrapping="Wrap" Margin="0,0,5,0"  VerticalAlignment="Center"/>
                        <ContentControl Grid.Column="2" Content="{Binding}"
                        ContentTemplateSelector="{StaticResource FormatSelector}"
                         IsEnabled="{Binding IsAvailable}"/>-->
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ui:NodeView>
