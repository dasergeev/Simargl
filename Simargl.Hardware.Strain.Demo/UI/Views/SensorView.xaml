<ui:NodeView
    x:Class="Simargl.Hardware.Strain.Demo.UI.Views.SensorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Simargl.Hardware.Strain.Demo.UI.Views"
    xmlns:ui="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    xmlns:nodes="clr-namespace:Simargl.Hardware.Strain.Demo.Nodes"
    xmlns:core="clr-namespace:Simargl.Hardware.Strain.Demo.Core"
    xmlns:prim="clr-namespace:Simargl.Hardware.Strain.Demo.UI.Primitives"
    d:DataContext="{d:DesignInstance Type=nodes:SensorNode}"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <ui:NodeView.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </ui:NodeView.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ToolBar x:Name="_ToolBar" ToolBarTray.IsLocked="True">
            <Button x:Name="_RebootButton" Click="RebootButton_Click" IsEnabled="{Binding Path=Sensor.IsConnected}">
                <!--Visibility="{Binding Path=Sensor.IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"-->
                <Image Source="/Images/Reboot.png" />
                <Button.ToolTip>
                    <StackPanel>
                        <TextBlock Text="Перезагрузить" FontWeight="Bold"/>
                        <TextBlock Text="Перезагрузить датчик.">
                            <TextBlock.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </StackPanel>
                </Button.ToolTip>
            </Button>
        </ToolBar>
        <TabControl Grid.Row="1">
            <TabItem Header="Информация">
                <prim:SensorAttributeCollectionView DataContext="{Binding Path=Sensor.Information}"/>
            </TabItem>
            <TabItem Header="Состояние">
                <prim:SensorAttributeCollectionView DataContext="{Binding Path=Sensor.Condition}"/>
            </TabItem>
            <TabItem Header="Настройки">
                <prim:SensorAttributeCollectionView DataContext="{Binding Path=Sensor.Settings}"/>
            </TabItem>
        </TabControl>
    </Grid>
</ui:NodeView>
