<ui:Control
    x:Class="Simargl.Hardware.Strain.Demo.UI.JournalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    xmlns:ui="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    xmlns:core="clr-namespace:Simargl.Hardware.Strain.Demo.Core"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <ui:Control.Resources>
        <core:JournalRecordLevelToImageConverter x:Key="JournalRecordLevelToImageConverter"/>
    </ui:Control.Resources>
    <Grid>
        <ListView x:Name="_ListView" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SizeChanged="ListView_SizeChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="136"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image
                            Width="16" Height="16"
                            Source="{Binding Level, Converter={StaticResource JournalRecordLevelToImageConverter}}"
                            VerticalAlignment="Top" HorizontalAlignment="Center"
                            Margin="0,2.5,0,0"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Time, StringFormat='{}{0:HH:mm:ss dd.MM.yyyy}'}"
                            VerticalAlignment="Top" HorizontalAlignment="Center"/>
                        <TextBlock
                            Grid.Column="2" Text="{Binding Text}"
                            TextWrapping="Wrap"
                            VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ui:Control>
