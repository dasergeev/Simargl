<ui:Control
    x:Class="Simargl.Hardware.Strain.Demo.UI.MainControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    xmlns:ui="clr-namespace:Simargl.Hardware.Strain.Demo.UI"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.RowSpan="2" Width="5" Background="Transparent"/>
        <GridSplitter Grid.Column="1" Grid.Row="1" Height="5" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
        <ui:Explorer Grid.RowSpan="2" Margin="0,0,5,0"/>
        <ui:Workspace Grid.Column="1"/>
        <ui:JournalView Grid.Column="1" Grid.Row="1" Margin="0,5,0,0"/>
    </Grid>
</ui:Control>
