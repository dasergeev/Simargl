<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Simargl.FlawDetector.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:Simargl.FlawDetector.Controls"
    xmlns:sourceEditors="clr-namespace:Simargl.FlawDetector.Controls.SourceEditors"
    xmlns:sourceViewModels="clr-namespace:Simargl.FlawDetector.ViewModels.Sources"
    mc:Ignorable="d"
    Title="Симулятор дефектов буксового подшипника"
    Width="1440"
    Height="920"
    MinWidth="1200"
    MinHeight="780"
    WindowState="Maximized">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate DataType="{x:Type sourceViewModels:WheelRotationSignalSourceViewModel}">
            <sourceEditors:WheelRotationSignalSourceEditorControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type sourceViewModels:TrackExcitationSignalSourceViewModel}">
            <sourceEditors:TrackExcitationSignalSourceEditorControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type sourceViewModels:StructuralResonanceSignalSourceViewModel}">
            <sourceEditors:StructuralResonanceSignalSourceEditorControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type sourceViewModels:DefectImpulseSignalSourceViewModel}">
            <sourceEditors:DefectImpulseSignalSourceEditorControl Faults="{Binding DataContext.Faults, RelativeSource={RelativeSource AncestorType=Window}}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type sourceViewModels:MeasurementNoiseSignalSourceViewModel}">
            <sourceEditors:MeasurementNoiseSignalSourceEditorControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type sourceViewModels:RealSensorSignalSourceViewModel}">
            <sourceEditors:RealSensorSignalSourceEditorControl />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" MinWidth="320" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="480" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Padding="14" CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Источники сигнала" />
                    <ListBox
                        Grid.Row="1"
                        Margin="0,12,0,0"
                        ItemsSource="{Binding Sources}"
                        SelectedItem="{Binding SelectedSignalSource}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <CheckBox
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding IsEnabled}" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding DisplayName}" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <GridSplitter
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ResizeDirection="Rows"
                ResizeBehavior="PreviousAndNext"
                ShowsPreview="True" />
            <Border Grid.Row="2" Padding="14" CornerRadius="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Параметры модели" />
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Sources[0].IsEnabled}" Value="False" />
                                                <Condition Binding="{Binding Sources[1].IsEnabled}" Value="False" />
                                                <Condition Binding="{Binding Sources[3].IsEnabled}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.ColumnSpan="2" FontSize="18" FontWeight="SemiBold" Text="Общие параметры движения" />
                                <TextBlock Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center" Text="Скорость вагона, км/ч" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="12,12,0,0" Text="{Binding WagonSpeedKilometersPerHour}" />
                                <TextBlock Grid.Row="2" Margin="0,12,0,0" VerticalAlignment="Center" Text="Диаметр колеса, мм" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="12,12,0,0" Text="{Binding WheelDiameterMillimeters}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Sources[3].IsEnabled}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.ColumnSpan="2" FontSize="18" FontWeight="SemiBold" Text="Общие параметры узла и регистрации" />
                                <TextBlock Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center" Text="Нагрузка на ось, кН" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="12,12,0,0" Text="{Binding AxleLoadKilonewtons}" />
                                <TextBlock Grid.Row="2" Margin="0,12,0,0" VerticalAlignment="Center" Text="Диаметр подшипника, мм" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="12,12,0,0" Text="{Binding BearingPitchDiameterMillimeters}" />
                                <TextBlock Grid.Row="3" Margin="0,12,0,0" VerticalAlignment="Center" Text="Диаметр тела качения, мм" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="12,12,0,0" Text="{Binding RollingElementDiameterMillimeters}" />
                                <TextBlock Grid.Row="4" Margin="0,12,0,0" VerticalAlignment="Center" Text="Число тел качения" />
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="12,12,0,0" Text="{Binding RollingElementCount}" />
                                <TextBlock Grid.Row="5" Margin="0,12,0,0" VerticalAlignment="Center" Text="Контактный угол, град" />
                                <TextBox Grid.Row="5" Grid.Column="1" Margin="12,12,0,0" Text="{Binding ContactAngleDegrees}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Sources[0].IsEnabled}" Value="False" />
                                                <Condition Binding="{Binding Sources[1].IsEnabled}" Value="False" />
                                                <Condition Binding="{Binding Sources[2].IsEnabled}" Value="False" />
                                                <Condition Binding="{Binding Sources[3].IsEnabled}" Value="False" />
                                                <Condition Binding="{Binding Sources[4].IsEnabled}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.ColumnSpan="2" FontSize="18" FontWeight="SemiBold" Text="Параметры регистрации" />
                                <TextBlock Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center" Text="Частота дискретизации" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="12,12,0,0" Text="{Binding SampleRate}" />
                                <TextBlock Grid.Row="2" Margin="0,12,0,0" VerticalAlignment="Center" Text="Длительность окна, с" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="12,12,0,0" Text="{Binding DurationSeconds}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Visibility="{Binding Sources[0].IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <sourceEditors:WheelRotationSignalSourceEditorControl DataContext="{Binding Sources[0]}" />
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Visibility="{Binding Sources[1].IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <sourceEditors:TrackExcitationSignalSourceEditorControl DataContext="{Binding Sources[1]}" />
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Visibility="{Binding Sources[2].IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <sourceEditors:StructuralResonanceSignalSourceEditorControl DataContext="{Binding Sources[2]}" />
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Visibility="{Binding Sources[3].IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <sourceEditors:DefectImpulseSignalSourceEditorControl DataContext="{Binding Sources[3]}" Faults="{Binding Faults}" />
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Visibility="{Binding Sources[4].IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <sourceEditors:MeasurementNoiseSignalSourceEditorControl DataContext="{Binding Sources[4]}" />
                        </Border>
                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Visibility="{Binding Sources[5].IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <sourceEditors:RealSensorSignalSourceEditorControl DataContext="{Binding Sources[5]}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        <GridSplitter
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ResizeDirection="Columns"
            ResizeBehavior="PreviousAndNext"
            ShowsPreview="True" />
        <Grid Grid.Column="2" Margin="0,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" MinHeight="180" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="0,0,0,14" Padding="18" CornerRadius="16">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Трёхкоординатный сигнал акселерометра" />
                            <Button Margin="16,0,0,0" Padding="12,6" Command="{Binding ToggleStreamingCommand}" Content="{Binding ToggleStreamingButtonText}" />
                            <Button Margin="8,0,0,0" Padding="12,6" Command="{Binding RestartCommand}" Content="Перезапустить" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding Summary}" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Margin="0,0,0,14" Padding="14" CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ось X" />
                            <TextBlock Margin="12,2,0,0" Text="{Binding XAxis.PeakAcceleration, StringFormat=Пик {0:F2} g}" />
                        </DockPanel>
                        <controls:SignalPlotControl Grid.Row="1" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Series="{Binding XAxis}" />
                    </Grid>
                </Border>
                <Border Grid.Row="2" Margin="0,0,0,14" Padding="14" CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ось Y" />
                            <TextBlock Margin="12,2,0,0" Text="{Binding YAxis.PeakAcceleration, StringFormat=Пик {0:F2} g}" />
                        </DockPanel>
                        <controls:SignalPlotControl Grid.Row="1" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Series="{Binding YAxis}" />
                    </Grid>
                </Border>
                <Border Grid.Row="3" Padding="14" CornerRadius="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ось Z" />
                            <TextBlock Margin="12,2,0,0" Text="{Binding ZAxis.PeakAcceleration, StringFormat=Пик {0:F2} g}" />
                        </DockPanel>
                        <controls:SignalPlotControl Grid.Row="1" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Series="{Binding ZAxis}" />
                    </Grid>
                </Border>
            </Grid>
            <GridSplitter
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ResizeDirection="Rows"
                ResizeBehavior="PreviousAndNext"
                ShowsPreview="True" />
            <Border Grid.Row="2" Padding="14" CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="120" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" MinHeight="120" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Область дальнейшего анализа" />
                    <Border
                        Grid.Row="1"
                        Margin="0,12,0,0"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                        <Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.75"
                                Text="Здесь будет размещён функционал анализа сигнала" />
                        </Grid>
                    </Border>
                    <GridSplitter
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ResizeDirection="Rows"
                        ResizeBehavior="PreviousAndNext"
                        ShowsPreview="True" />
                    <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
                        <Button Padding="12,6" Command="{Binding ToggleLogPauseCommand}" Content="{Binding LogPauseButtonText}" />
                    </DockPanel>
                    <TextBox
                        x:Name="LogTextBox"
                        Grid.Row="4"
                        Margin="0,12,0,0"
                        Padding="8"
                        Text="{Binding LogText, Mode=OneWay}"
                        BorderThickness="0"
                        Background="Transparent"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        IsReadOnlyCaretVisible="True"
                        TextWrapping="NoWrap"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>





