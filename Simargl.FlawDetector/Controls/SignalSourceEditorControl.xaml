<UserControl
    x:Class="Simargl.FlawDetector.Controls.SignalSourceEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:Simargl.FlawDetector.Controls"
    xmlns:models="clr-namespace:Simargl.FlawDetector.Models"
    mc:Ignorable="d"
    d:DesignHeight="420"
    d:DesignWidth="420">
    <UserControl.Resources>
        <DataTemplate x:Key="NoSourceTemplate">
            <Border Padding="16">
                <TextBlock TextWrapping="Wrap" Text="Выберите источник сигнала в списке слева." />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="WheelRotationSourceTemplate">
            <StackPanel DataContext="{Binding Source, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Вращение колесной пары" />
                <CheckBox Margin="0,10,0,0" Content="Использовать источник" IsChecked="{Binding IsEnabled}" />
                <TextBlock Margin="0,12,0,0" Text="Уровень вращательной вибрации" />
                <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding AmplitudeScale}" />
                <TextBlock HorizontalAlignment="Right" Text="{Binding AmplitudeScale, StringFormat=F2}" />
                <TextBlock Margin="0,8,0,0" Text="Насыщенность гармониками" />
                <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding DetailScale}" />
                <TextBlock HorizontalAlignment="Right" Text="{Binding DetailScale, StringFormat=F2}" />
                <CheckBox Margin="0,8,0,0" Content="Добавить эксцентриситет" IsChecked="{Binding IsAuxiliaryEnabled}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="TrackExcitationSourceTemplate">
            <StackPanel DataContext="{Binding Source, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Возбуждение от пути" />
                <CheckBox Margin="0,10,0,0" Content="Использовать источник" IsChecked="{Binding IsEnabled}" />
                <TextBlock Margin="0,12,0,0" Text="Тип профиля пути" />
                <ComboBox SelectedIndex="{Binding ModeIndex}" ItemsSource="{Binding ModeOptions}" />
                <TextBlock Margin="0,8,0,0" Text="Интенсивность воздействия" />
                <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding AmplitudeScale}" />
                <TextBlock HorizontalAlignment="Right" Text="{Binding AmplitudeScale, StringFormat=F2}" />
                <CheckBox Margin="0,8,0,0" Content="Добавить удары от стыков" IsChecked="{Binding IsAuxiliaryEnabled}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="StructuralResonanceSourceTemplate">
            <StackPanel DataContext="{Binding Source, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Структурный резонанс" />
                <CheckBox Margin="0,10,0,0" Content="Использовать источник" IsChecked="{Binding IsEnabled}" />
                <TextBlock Margin="0,12,0,0" Text="Резонансный контур" />
                <ComboBox SelectedIndex="{Binding ModeIndex}" ItemsSource="{Binding ModeOptions}" />
                <TextBlock Margin="0,8,0,0" Text="Демпфирование" />
                <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding DetailScale}" />
                <TextBlock HorizontalAlignment="Right" Text="{Binding DetailScale, StringFormat=F2}" />
                <CheckBox Margin="0,8,0,0" Content="Усилить вклад по оси Z" IsChecked="{Binding IsAuxiliaryEnabled}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="DefectImpulsesSourceTemplate">
            <Grid DataContext="{Binding Source, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Text="Импульсы дефектов подшипника" />
                <CheckBox Grid.Row="1" Margin="0,10,0,0" Content="Использовать источник" IsChecked="{Binding IsEnabled}" />
                <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="Режим дефектного отклика" />
                <ComboBox Grid.Row="2" Margin="0,24,0,0" SelectedIndex="{Binding ModeIndex}" ItemsSource="{Binding ModeOptions}" />
                <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="Энергия импульсов" />
                <Slider Grid.Row="3" Margin="0,24,0,0" Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding AmplitudeScale}" />
                <TextBlock Grid.Row="3" Margin="0,48,0,0" HorizontalAlignment="Right" Text="{Binding AmplitudeScale, StringFormat=F2}" />
                <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="Острота импульсов" />
                <Slider Grid.Row="4" Margin="0,24,0,0" Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding DetailScale}" />
                <TextBlock Grid.Row="4" Margin="0,48,0,0" HorizontalAlignment="Right" Text="{Binding DetailScale, StringFormat=F2}" />
                <ScrollViewer Grid.Row="5" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <CheckBox Margin="0,0,0,8" Content="Добавить боковые полосы модуляции" IsChecked="{Binding IsAuxiliaryEnabled}" />
                        <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Параметры дефектов" />
                        <ItemsControl ItemsSource="{Binding Faults, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="10">
                                        <StackPanel>
                                            <CheckBox FontWeight="SemiBold" Content="{Binding DisplayName}" IsChecked="{Binding IsEnabled}" />
                                            <Grid Margin="0,8,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="52" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="Тяжесть" />
                                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding Severity}" />
                                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding Severity, StringFormat=F2}" />
                                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Ударность" />
                                                <Slider Grid.Row="1" Grid.Column="1" Minimum="0.05" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding ImpactFactor}" />
                                                <TextBlock Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding ImpactFactor, StringFormat=F2}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="MeasurementNoiseSourceTemplate">
            <StackPanel DataContext="{Binding Source, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Измерительный шум" />
                <CheckBox Margin="0,10,0,0" Content="Использовать источник" IsChecked="{Binding IsEnabled}" />
                <TextBlock Margin="0,12,0,0" Text="Тип спектра" />
                <ComboBox SelectedIndex="{Binding ModeIndex}" ItemsSource="{Binding ModeOptions}" />
                <TextBlock Margin="0,8,0,0" Text="Уровень шума" />
                <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding AmplitudeScale}" />
                <TextBlock HorizontalAlignment="Right" Text="{Binding AmplitudeScale, StringFormat=F2}" />
                <CheckBox Margin="0,8,0,0" Content="Пакетный режим шума" IsChecked="{Binding IsAuxiliaryEnabled}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Border Padding="12" CornerRadius="12">
        <ContentControl Content="{Binding Source, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate" Value="{StaticResource NoSourceTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Source.SourceType, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}" Value="{x:Static models:SignalSourceType.WheelRotation}">
                            <Setter Property="ContentTemplate" Value="{StaticResource WheelRotationSourceTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source.SourceType, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}" Value="{x:Static models:SignalSourceType.TrackExcitation}">
                            <Setter Property="ContentTemplate" Value="{StaticResource TrackExcitationSourceTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source.SourceType, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}" Value="{x:Static models:SignalSourceType.StructuralResonance}">
                            <Setter Property="ContentTemplate" Value="{StaticResource StructuralResonanceSourceTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source.SourceType, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}" Value="{x:Static models:SignalSourceType.DefectImpulses}">
                            <Setter Property="ContentTemplate" Value="{StaticResource DefectImpulsesSourceTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source.SourceType, RelativeSource={RelativeSource AncestorType=controls:SignalSourceEditorControl}}" Value="{x:Static models:SignalSourceType.MeasurementNoise}">
                            <Setter Property="ContentTemplate" Value="{StaticResource MeasurementNoiseSourceTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Border>
</UserControl>
