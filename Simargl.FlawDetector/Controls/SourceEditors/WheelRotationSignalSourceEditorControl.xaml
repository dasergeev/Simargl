<UserControl
    x:Class="Simargl.FlawDetector.Controls.SourceEditors.WheelRotationSignalSourceEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="320"
    d:DesignWidth="360">
    <StackPanel>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Вращение колесной пары" />
        <CheckBox Margin="0,10,0,0" Content="Использовать источник" IsChecked="{Binding IsEnabled}" />
        <TextBlock Margin="0,12,0,0" Text="Уровень вращательной вибрации" />
        <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding AmplitudeScale}" />
        <TextBlock HorizontalAlignment="Right" Text="{Binding AmplitudeScale, StringFormat=F2}" />
        <TextBlock Margin="0,8,0,0" Text="Насыщенность гармониками" />
        <Slider Minimum="0.1" Maximum="4" TickFrequency="0.1" IsSnapToTickEnabled="False" Value="{Binding HarmonicContent}" />
        <TextBlock HorizontalAlignment="Right" Text="{Binding HarmonicContent, StringFormat=F2}" />
        <CheckBox Margin="0,8,0,0" Content="Добавить эксцентриситет" IsChecked="{Binding IncludeEccentricity}" />
    </StackPanel>
</UserControl>
