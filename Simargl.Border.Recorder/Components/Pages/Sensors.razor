@page "/sensors"
@using Simargl.Border.Recorder.Components.Common
@using Simargl.Border.Hardware
@using Simargl.Border.Processing
@using Simargl.Net
@inject Program Program
@implements IAsyncDisposable

@rendermode InteractiveServer
<PageTitle>Датчики</PageTitle>

<h1>Датчики</h1>

<InputSelect TValue="long" class="form-select"
             @bind-Value="_SelectedDeviceAddressValue">
    @foreach (Device sensor in _Devices)
    {
        <option value="@sensor.Address.Value">@sensor.Address.ToString()</option>
    }
</InputSelect>

@if (_SelectedDevice is not null)
{
    <h3>Статистика</h3>
    <table class="table table-sm table-hover"
           style="table-layout: fixed; width: 100%;">
        <thead>
            <tr>
                <th>Параметр</th>
                <th>Значение</th>
                <th>Единица измерения</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in _SelectedDevice.Statistics)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Value</td>
                    <td>@p.Unit</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Канал 1</h3>
    <Plotter Points="_SelectedDevice.Preview.GetPoints(0)"
        ContainerStyle="width:100%; aspect-ratio: 100 / 36;"
        TargetXTicks="10"
        TargetYTicks="6" />
    <h3>Канал 2</h3>
    <Plotter Points="_SelectedDevice.Preview.GetPoints(1)"
        ContainerStyle="width:100%; aspect-ratio: 100 / 36;"
        TargetXTicks="10"
        TargetYTicks="6" />
    <h3>Канал 3</h3>
    <Plotter Points="_SelectedDevice.Preview.GetPoints(2)"
        ContainerStyle="width:100%; aspect-ratio: 100 / 36;"
        TargetXTicks="10"
        TargetYTicks="6" />
}

@* 

<NiceScatter Points="Kernel.Root.SensorCollectionNode.Sensors[_SelectedSensorIndex].Analyser.Points"
                 ContainerStyle="width:100%; height:420px;"
                 TargetXTicks="10"
                 TargetYTicks="6" />

<ProcessorView SensorBase="Kernel.Root.SensorCollectionNode.Sensors[_SelectedSensorIndex]" />
 *@

@code {

    private long _SelectedDeviceAddressValue;
    private Device[] _Devices = [];
    private Device? _SelectedDevice = null;

    private readonly CancellationTokenSource _CancellationTokenSource = new();

    protected override async Task OnInitializedAsync()
    {
        //  Получение устройства обработки.
        Processor processor = await Program.GetProcessorAsync(default).ConfigureAwait(false);

        _Devices = processor.Devices.OrderBy(x => x.Address).ToArray();
        if (_SelectedDeviceAddressValue == 0 && _Devices.Length > 0)
        {
            _SelectedDeviceAddressValue = _Devices[0].Address.Value;
        }

        CancellationToken cancellationToken = _CancellationTokenSource.Token;
        _ = Task.Run(async delegate
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                _Devices = processor.Devices.OrderBy(x => x.Address).ToArray();
                if (_SelectedDeviceAddressValue == 0 && _Devices.Length > 0)
                {
                    _SelectedDeviceAddressValue = _Devices[0].Address.Value;
                }

                try
                {
                    _SelectedDevice = _SelectedDeviceAddressValue != 0 ? processor.Devices[new(_SelectedDeviceAddressValue)] : null;
                }
                catch
                {
                    _SelectedDevice = null;
                }

                await InvokeAsync(StateHasChanged);

                await Task.Delay(500, cancellationToken).ConfigureAwait(false);
            }
        }, cancellationToken).ConfigureAwait(false);
    }

    public async ValueTask DisposeAsync()
    {
        _CancellationTokenSource.Dispose();
    }
}