<Window x:Class="Simargl.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Simargl.Viewer — просмотр файла регистрации"
        Width="1500"
        Height="920"
        MinWidth="1280"
        MinHeight="800"
        AllowDrop="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Margin="16,16,16,0"
                    MinHeight="190">
            <TabItem Header="Файл">
                <Grid Margin="12"
                      MinHeight="136">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Открытие">
                        <StackPanel Margin="8"
                                    Orientation="Horizontal">
                            <Button x:Name="OpenFileButton"
                                    MinWidth="140"
                                    Margin="0,0,8,0"
                                    Click="OpenFileButton_Click"
                                    Content="Открыть файл" />
                            <Button x:Name="ReloadFileButton"
                                    MinWidth="160"
                                    IsEnabled="False"
                                    Click="ReloadFileButton_Click"
                                    Content="Открыть повторно" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="2"
                              Header="Текущий файл">
                        <TextBlock x:Name="CurrentFileTextBlock"
                                   Margin="8"
                                   TextWrapping="Wrap"
                                   Text="Файл не открыт." />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Просмотр">
                <Grid Margin="12"
                      MinHeight="136">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Режим">
                        <StackPanel Margin="8"
                                    Orientation="Horizontal">
                            <StackPanel Width="220">
                                <TextBlock Text="График" />
                                <ComboBox x:Name="DisplayModeComboBox"
                                          Margin="0,6,0,0"
                                          SelectionChanged="DisplayModeComboBox_SelectionChanged">
                                    <ComboBoxItem IsSelected="True"
                                                  Tag="Actual"
                                                  Content="Фактические значения" />
                                    <ComboBoxItem Tag="Raw"
                                                  Content="Исходные значения" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Width="180"
                                        Margin="12,0,0,0">
                                <TextBlock Text="Окно" />
                                <ComboBox x:Name="WindowSizeComboBox"
                                          Margin="0,6,0,0"
                                          SelectionChanged="WindowSizeComboBox_SelectionChanged">
                                    <ComboBoxItem IsSelected="True"
                                                  Tag="0"
                                                  Content="Все точки" />
                                    <ComboBoxItem Tag="1000"
                                                  Content="1000 точек" />
                                    <ComboBoxItem Tag="5000"
                                                  Content="5000 точек" />
                                    <ComboBoxItem Tag="10000"
                                                  Content="10000 точек" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="2"
                              Header="Курсор">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Диапазон X" />
                            <TextBlock x:Name="VisibleRangeTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="2"
                                       Text="—" />

                            <TextBlock Grid.Row="1"
                                       Text="Значения" />
                            <TextBlock x:Name="HoverValueTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Text="—"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="4"
                              Header="Подсказка">
                        <TextBlock Margin="8"
                                   TextWrapping="Wrap"
                                   Text="Отмечайте каналы справа, чтобы сравнивать их на одном графике. Цвет в списке соответствует цвету линии." />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Навигация">
                <Grid Margin="12"
                      MinHeight="136">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Ось X">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Начало" />
                            <TextBlock x:Name="XStartScaleTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="2"
                                       Text="—" />

                            <TextBlock Grid.Row="1"
                                       Text="Конец" />
                            <TextBlock x:Name="XEndScaleTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Text="—" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="2"
                              Header="Ось Y">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Верхняя отметка" />
                            <TextBlock x:Name="YTopScaleTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="2"
                                       Text="—" />

                            <TextBlock Grid.Row="1"
                                       Text="Нижняя отметка" />
                            <TextBlock x:Name="YBottomScaleTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Text="—" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="4"
                              Header="Диапазон">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Минимум" />
                            <TextBlock x:Name="MinValueTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="2"
                                       Text="Min: —" />

                            <TextBlock Grid.Row="1"
                                       Text="Максимум" />
                            <TextBlock x:Name="MaxValueTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Text="Max: —" />

                            <TextBlock Grid.Row="2"
                                       Text="Точек" />
                            <TextBlock x:Name="PointCountTextBlock"
                                       Grid.Row="2"
                                       Grid.Column="2"
                                       Text="Точек: —" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1"
              Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="График">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0"
                          Grid.Column="0"
                          Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock HorizontalAlignment="Right"
                                   Text="{Binding ElementName=YTopScaleTextBlock, Path=Text}" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="Y" />
                        <TextBlock Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Text="{Binding ElementName=YBottomScaleTextBlock, Path=Text}" />
                    </Grid>

                    <Canvas x:Name="PlotCanvas"
                            Grid.Row="0"
                            Grid.Column="1"
                            MinHeight="520"
                            SizeChanged="PlotCanvas_SizeChanged"
                            MouseLeave="PlotCanvas_MouseLeave"
                            MouseMove="PlotCanvas_MouseMove">
                        <Line x:Name="PlotAxisX"
                              Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                              StrokeThickness="1" />
                        <Line x:Name="PlotAxisY"
                              Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                              StrokeThickness="1" />
                    </Canvas>

                    <Grid Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Slider x:Name="ViewportSlider"
                                Grid.Row="0"
                                Minimum="0"
                                Maximum="0"
                                IsSnapToTickEnabled="False"
                                ValueChanged="ViewportSlider_ValueChanged" />

                        <Grid Grid.Row="1"
                              Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding ElementName=XStartScaleTextBlock, Path=Text}" />
                            <TextBlock Grid.Column="1"
                                       HorizontalAlignment="Center"
                                       Text="X" />
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       Text="{Binding ElementName=XEndScaleTextBlock, Path=Text}" />
                        </Grid>
                    </Grid>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" />

            <GroupBox Grid.Column="2"
                      Header="Каналы">
                <ListBox x:Name="ChannelsListBox"
                         Margin="8"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          VerticalContentAlignment="Center"
                                          Click="ChannelVisibilityCheckBox_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="14"
                                                Height="14"
                                                Margin="0,2,0,0"
                                                VerticalAlignment="Top"
                                                Background="{Binding ChannelBrush}"
                                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                                BorderThickness="1"
                                                CornerRadius="2" />

                                        <StackPanel Grid.Column="2">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Opacity="0.8"
                                                       Text="{Binding Description}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Opacity="0.7"
                                                       Text="{Binding MetaText}" />
                                        </StackPanel>
                                    </Grid>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="2"
                   Margin="16,0,16,16">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock"
                           Text="Готово." />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
