@page
@using Simargl.Web.Site.Core
@model Simargl.Web.Site.Pages.ServicesModel
@{
    ViewData["Title"] = "Услуги";
}

<div class="container mt-4">
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var group in ServiceGroup.ServiceGroups)
        {
            <div class="col">
                <a asp-page="/Services/Group" asp-route-key="@group.Key" class="text-decoration-none text-dark">
                    <div class="card h-100 shadow-sm service-card">
                        <img src="@group.ImageUrl" class="card-img-top" alt="@group.Name" />
                        <div class="card-body">
                            <h5 class="card-title">@group.Name</h5>
                            <p class="card-text">@group.Description</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
