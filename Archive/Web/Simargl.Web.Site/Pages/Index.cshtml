@page
@using Simargl.Web.Site.Core
@model IndexModel
@{
    ViewData["Title"] = "Главная";
}

<h1 class="display-5 fw-bold text-center mt-4">Инженерные решения и технологии для промышленности</h1>
<p class="lead text-center">Проектирование, контроль, программное обеспечение и сопровождение на всех этапах жизненного цикла продукции</p>


<div class="container mt-4">
    <div class="auto-scroll-container">
        <div id="scroll-track" class="auto-scroll-track">
            @foreach (var group in ServiceGroup.ServiceGroups.Concat(ServiceGroup.ServiceGroups))
            {
                <div class="scroll-tile">
                    <a asp-page="/Services/Group" asp-route-key="@group.Key" class="text-decoration-none text-dark">
                        <div class="card h-100 shadow-sm">
                            <img src="@group.ImageUrl" class="card-img-top" alt="@group.Name" />
                            <div class="card-body">
                                <h5 class="card-title">@group.Name</h5>
                                @* <p class="card-text">@group.Description</p> *@
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>


