<UserControl x:Class="Apeiron.Oriole.DatabaseConfigurator.EntityControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DatabaseConfigurator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="LayoutGrid">
        <DockPanel LastChildFill="True">

            <!--<Button x:Name="EntitySaveButton" Content="Сохранить данные" Height="25" DockPanel.Dock="Bottom" /> -->
            
            <!--Таблица с данными-->
            <DataGrid x:Name="EntityDataGrid" DockPanel.Dock="Top" DataContext="{Binding UpdateSourceTrigger=Explicit, IsAsync=True}">
                
            </DataGrid>
            
            
        </DockPanel>
    </Grid>
</UserControl>
