<UserControl x:Class="Apeiron.Platform.Demo.AdxlDemo.UserInterface.Explorer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Apeiron.Platform.Demo.AdxlDemo.UserInterface"
             xmlns:converters="clr-namespace:Apeiron.Platform.Demo.AdxlDemo.UserInterface.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:NodeFormatToImageConverter x:Key="NodeFormatToImageConverter"/>
    </UserControl.Resources>
    <Grid>
        <TreeView x:Name="_TreeView" BorderThickness="0" SelectedItemChanged="TreeView_SelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Path=Nodes}">
                    <StackPanel Orientation="Horizontal">
                        <Image Name="img"
                           Width="16"
                           Height="16"
                           Stretch="Fill"
                           Source="{Binding NodeFormat, Converter={StaticResource NodeFormatToImageConverter}}"/>
                        <TextBlock Text="{Binding Name}" Margin="5,0"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
