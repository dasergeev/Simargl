<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PointerDataViewer"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <!--xmlns:WPF="clr-namespace:Steema.TeeChart.WPF;assembly=TeeChart.WPF"
        xmlns:Drawing="clr-namespace:Steema.TeeChart.Drawing;assembly=TeeChart" xmlns:PointerDataViewer="clr-namespace:PointerDataViewer;assembly=ParserSensorsFiles" x:Class="PointerDataViewer.MainWindow"-->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Height="20" VerticalAlignment="Top">
            <MenuItem Header="Server" Grid.Row="0">
                <MenuItem  Header="Start"  /> <!--Click="MenuItem_Click_2"-->
            </MenuItem>
            <MenuItem Header="Mtp" Grid.Row="0">
                <MenuItem  Header="Open file" /> <!--Click="MenuItem_Click_1"-->
            </MenuItem>
        </Menu>
        <TabControl Grid.Row ="2">
            <TabItem Header="File">
                <Grid Background="#FFE5E5E5">
                    <!--<WPF:TChart x:Name="_FileChart" VerticalAlignment="Center" />-->
                </Grid>
            </TabItem>
            <TabItem Header="MTP" Margin="-2,0,-2,0">
                <Grid Background="#FFE5E5E5">
                    <!--<WPF:TChart x:Name="_MtpStreamChart" VerticalAlignment="Center" />-->
                </Grid>
            </TabItem>
            <TabItem Header="Adxl" Margin="-2,0,-2,0">
                <Grid Background="#FFE5E5E5">
                    <!--<WPF:TChart x:Name="_AdxlStreamChart" VerticalAlignment="Center" />-->
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
