<lui:LocalControl
    x:Class="Simargl.AccelEth3T.AccelEth3TViewer.UI.Explorer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Simargl.AccelEth3T.AccelEth3TViewer.UI"
    xmlns:lui="clr-namespace:Simargl.AccelEth3T.AccelEth3TViewer.UI"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <TreeView
        x:Name="_TreeView"
        BorderThickness="0"
        SelectedItemChanged="TreeView_SelectedItemChanged"
        TreeViewItem.Selected="TreeViewItem_Selected"
        TreeViewItem.Unselected="TreeViewItem_Unselected"
        TreeViewItem.Expanded="TreeViewItem_Expanded"
        TreeViewItem.Collapsed="TreeViewItem_Collapsed">
        <TreeView.ItemContainerStyle>
            <Style TargetType="{x:Type TreeViewItem}">
                <Setter Property="IsSelected" Value="{Binding IsSelected}" />
                <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
            </Style>
        </TreeView.ItemContainerStyle>
        <TreeView.ItemTemplate>
            <HierarchicalDataTemplate ItemsSource="{Binding Path=Nodes}">
                <TextBlock Text="{Binding Name}" />
            </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</lui:LocalControl>
