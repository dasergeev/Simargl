<Window x:Class="Simargl.AccelEth3T.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Simargl.AccelEth3T"
        mc:Ignorable="d"
        Title="Настройка Акселерометров AccelEth-3T" Height="450" Width="800" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <local:DeviceView x:Name="_DeviceView" Margin="4,0,4,4" Grid.Column="1"/>
        <WindowsFormsHost x:Name="_Host" Grid.Column="2" Grid.RowSpan="2"/>
        <TextBox x:Name="_TextBox" Grid.Column="1" Grid.Row="1" BorderThickness="0" Margin="4,0,4,0" FontFamily="Consolas" AcceptsTab="True" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible" ScrollViewer.CanContentScroll="True" FontSize="12"/>
        <GridSplitter Grid.Column="1" HorizontalAlignment="Left" Width="4" Grid.RowSpan="2"/>
        <GridSplitter Grid.Column="1" Grid.RowSpan="2" Width="4"/>
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Height="4" VerticalAlignment="Bottom"/>
        <Grid Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ToolBar>
                <Button x:Name="_StartButton" Click="Start_Click" >
                    <Image Source="/Main/Start.png" Width="16" Height="16"/>
                </Button>
                <Button x:Name="_StopButton" Click="Stop_Click" Visibility="Collapsed">
                    <Image Source="/Main/StopHS.png" Width="16" Height="16"/>
                </Button>
            </ToolBar>
            <TreeView x:Name="_TreeView" BorderThickness="0" Grid.Row="1" SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Path=Nodes}">
                        <TextBlock Text="{Binding Name}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
    </Grid>
</Window>
