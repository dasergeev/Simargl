<UserControl x:Class="Apeiron.Platform.Software.ChannelAdditor.UserInterface.Editor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Apeiron.Platform.Software.ChannelAdditor.UserInterface"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="_Grid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="64"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Путь к исходным кадрам:" Margin="10,2,2,2" />
        <TextBlock Text="Путь к новым кадрам:" Grid.Row="1" Margin="10,2,2,2" />
        <TextBox Grid.Column="1" Margin="2,2,2,2" Text="{Binding Path=SourcePath}"/>
        <TextBox Grid.Column="1" Grid.Row="1" Margin="2,2,2,2" Text="{Binding Path=TargetPath}"/>
        <CheckBox Content="Включить вложенные каталоги" Grid.Column="1" Grid.Row="2" Margin="2" IsChecked="{Binding Path=IsNested}"/>
        <Button x:Name="_SourceButton" Grid.Column="2" Content="..." Margin="2" Click="SourceButton_Click"/>
        <Button x:Name="_TargetButton" Grid.Column="2" Grid.Row="1" Content="..." Margin="2" Click="TargetButton_Click"/>
        <GroupBox Header="Добавляемые каналы" Grid.Row="3" Grid.ColumnSpan="3" Margin="2">
            <ListView x:Name="_ListView" BorderThickness="0" SelectionChanged="ListView_SelectionChanged" IsSynchronizedWithCurrentItem="True">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Имя канала" Width="128">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=Name}" Background="Transparent" BorderThickness="0" MinWidth="128"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Значение" Width="128">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=Value}" Background="Transparent" BorderThickness="0" MinWidth="128"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Единица измерения" Width="128">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=Unit}" Background="Transparent" BorderThickness="0" MinWidth="128"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Частота" Width="128">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=Sampling}" Background="Transparent" BorderThickness="0" MinWidth="128"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Срез фильтра" Width="128">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=Cutoff}" Background="Transparent" BorderThickness="0" MinWidth="128"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            <!--<DataGrid x:Name="_DataGrid" AutoGenerateColumns="False" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Path=Name}"/>
                    <DataGridTextColumn Header="Единица" Binding="{Binding Path=Unit}"/>
                    <DataGridTextColumn Header="Частота" Binding="{Binding Path=Sampling}"/>
                    <DataGridTextColumn Header="Срез" Binding="{Binding Path=Cutoff}"/>
                    <DataGridTextColumn Header="Значение" Binding="{Binding Path=Value}"/>
                </DataGrid.Columns>
            </DataGrid>-->
        </GroupBox>

    </Grid>
</UserControl>
