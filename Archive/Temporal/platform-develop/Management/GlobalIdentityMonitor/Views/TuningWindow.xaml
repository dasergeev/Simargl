<Window x:Class="Apeiron.Services.GlobalIdentity.TuningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Apeiron.Services.GlobalIdentity.ViewModels"
        xmlns:Converters="clr-namespace:Apeiron.Services.GlobalIdentity.Converters"
        mc:Ignorable="d"
        Title="Настройки программы" Height="190" Width="300"
        WindowStartupLocation="CenterScreen">

    <!--Модель-Представление окна-->
    <Window.DataContext>
        <vm:TuningWindowViewModel x:Name="TuningWindowViewModel"/>
    </Window.DataContext>

    <!--ГЛОБАЛЬНЫЕ СТИЛИ, РЕСУРСЫ, КОНВЕРТЕРЫ-->
    <Window.Resources>

        <!--Конвертеры-->
        <Converters:MultiBindingTuningValueConverter x:Key="MultiBindingTuningValueConverter"/>

        <!--Стили-->
        <Style TargetType="Label" x:Key="LabelStyle">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox" x:Key="TextBoxStyle">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MaxLength" Value="50" />
            <Setter Property="Height" Value="auto" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="45*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="150*"/>
            <ColumnDefinition Width="130*"/>
            <ColumnDefinition Width="10*"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="TunningLabel" Content="Настройки программы"
               Style="{StaticResource LabelStyle}"
               Grid.Column="0" Grid.ColumnSpan="3"
               Width="170" FontWeight="Bold"/>
        <Label x:Name="RefreshPeriodLabel" Content="Период опроса БД в мс." 
               Style="{StaticResource LabelStyle}" 
               Grid.Column="1" Grid.Row="1" />
        <Label x:Name="KeepAlivePeriodLabel" Content="Таймаут системы в мин." 
               Style="{StaticResource LabelStyle}" 
               Grid.Column="1" Grid.Row="2" />

        <TextBox x:Name="RefreshPeriodTextBox" 
                 Text="{Binding Path = RefreshPeriod}"
                 Style="{StaticResource TextBoxStyle}"
                 Grid.Column="2" Grid.Row="1"/>

        <TextBox x:Name="KeepAlivePeriodTextBox" 
                 Text="{Binding Path = KeepAlivePeriod}" 
                 Style="{StaticResource TextBoxStyle}"
                 Grid.Column="2" Grid.Row="2" 
                 IsReadOnly="False" IsEnabled="True"/>

        <Button x:Name="TunningSaveButton" Content="Сохранить и применить настройки" 
                Grid.Column ="1"  Grid.ColumnSpan="2" Grid.Row="3" Height="25"
                Command="{Binding UpdateTuningsValuesCommand}">
            <Button.CommandParameter>
                <MultiBinding Converter="{StaticResource MultiBindingTuningValueConverter}">
                    <Binding Path="Text" ElementName="RefreshPeriodTextBox" />
                    <Binding Path="Text" ElementName="KeepAlivePeriodTextBox" />
                </MultiBinding>
            </Button.CommandParameter>
        </Button>
    </Grid>
</Window>
