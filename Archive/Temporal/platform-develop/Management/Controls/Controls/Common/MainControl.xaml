<UserControl x:Class="Apeiron.Platform.Management.Controls.MainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Apeiron.Platform.Management.Controls" xmlns:models="clr-namespace:Apeiron.Platform.Management.Models" d:DataContext="{d:DesignInstance Type=models:Model}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:Explorer x:Name="_Explorer"/>
        <local:WorkSpace x:Name="_WorkSpace" Grid.Column="1" Margin="5,0,0,0"/>
        <GridSplitter x:Name="gridSplitter" Grid.Column="1" HorizontalAlignment="Left" Width="5"/>

    </Grid>
</UserControl>
