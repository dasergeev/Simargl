<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CommutatorMaui.ChatsPage"
             xmlns:converters="clr-namespace:CommutatorMaui"
>

    <ContentPage.Resources>
        <converters:DateTimeStringConverter x:Key="DateTimeStringConverter"/>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ListView x:Name="_listDialog"
                      ItemsSource="{Binding Dialogs}"
                      BackgroundColor="AliceBlue"
                      HasUnevenRows="True"
                      ItemTapped="ListDialog_ItemTapped"
                      SeparatorVisibility="None"
                      SelectionMode="Single">
            
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.RowSpan="2"
                               Source="user.png"
                               Aspect="Fill"
                            />

                            <Label Text="{Binding Companion.Name}"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               HorizontalTextAlignment="Start"
                               TextColor="Black"
                            />

                            <Label Text="{Binding LastMessage.Text}"
                               Grid.Column="1"
                               Grid.Row="1"
                               TextColor="DarkGreen"
                               HorizontalTextAlignment="Center"

                            />

                            <Label Text="{Binding LastMessage.RegistrationTime, Converter={StaticResource DateTimeStringConverter}}"
                               Grid.Column="2"
                               Grid.Row="1"
                               TextColor="DarkGreen"
                               HorizontalTextAlignment="Center"

                            />

                        </Grid>
                    </ViewCell>
                    
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>


</ContentPage>