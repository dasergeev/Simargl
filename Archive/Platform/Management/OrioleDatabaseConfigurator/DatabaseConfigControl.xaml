<UserControl x:Class="Apeiron.Oriole.DatabaseConfigurator.DatabaseConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Apeiron.Oriole.DatabaseConfigurator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!--ГЛОБАЛЬНЫЕ СТИЛИ, РЕСУРСЫ, КОНВЕРТЕРЫ-->
    <UserControl.Resources>

    </UserControl.Resources>
    
    <Grid>
        <Grid x:Name="DatabaseConfigGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="5*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="17*"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="DBNameLabel" Content="Имя БД:" Grid.Column="0" Grid.Row="0"
                   VerticalAlignment="Center"/>
            <Label x:Name="DBServerLabel" Content="Сервер БД \ экземпляр:" Grid.Column="0" Grid.Row="1"
                   VerticalAlignment="Center"/>
            <Label x:Name="DBUser" Content="Имя пользователя:" Grid.Column="0" Grid.Row="2"
                   VerticalAlignment="Center"/>
                        
        </Grid>
    </Grid>
</UserControl>
