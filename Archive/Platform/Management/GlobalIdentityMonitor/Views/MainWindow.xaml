<Window x:Class="Apeiron.Services.GlobalIdentity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Converters="clr-namespace:Apeiron.Services.GlobalIdentity.Converters"
        xmlns:vm="clr-namespace:Apeiron.Services.GlobalIdentity.ViewModels" 
        xmlns:cmd="clr-namespace:Apeiron.Services.GlobalIdentity.Commands"
        mc:Ignorable="d"
        Title="{Binding Path=Title}" 
        Height="600" Width="890"
        x:Name="GlobalIdentityMonitor">

    <!--Модель-Представление окна-->
    <Window.DataContext>
        <vm:MainWindowViewModel x:Name="MainWindowViewModel"/>
    </Window.DataContext>

    <!-- Команды окна-->
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="Q" Command="{Binding CloseApplicationCommand}" />
    </Window.InputBindings>

    <!--ГЛОБАЛЬНЫЕ СТИЛИ, РЕСУРСЫ, КОНВЕРТЕРЫ-->
    <Window.Resources>
        <!--Иконки-->
        <!--<Canvas x:Key="SettingsIcon" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Path Fill="MediumPurple" Data="M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.21,15.05 2.27,14.78 2.46,14.63L4.57,12.97L4.5,12L4.57,11L2.46,9.37C2.27,9.22 2.21,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.79,8.95 21.73,9.22 21.54,9.37L19.43,11L19.5,12L19.43,13L21.54,14.63C21.73,14.78 21.79,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10M11.25,4L10.88,6.61C9.68,6.86 8.62,7.5 7.85,8.39L5.44,7.35L4.69,8.65L6.8,10.2C6.4,11.37 6.4,12.64 6.8,13.8L4.68,15.36L5.43,16.66L7.86,15.62C8.63,16.5 9.68,17.14 10.87,17.38L11.24,20H12.76L13.13,17.39C14.32,17.14 15.37,16.5 16.14,15.62L18.57,16.66L19.32,15.36L17.2,13.81C17.6,12.64 17.6,11.37 17.2,10.2L19.31,8.65L18.56,7.35L16.15,8.39C15.38,7.5 14.32,6.86 13.12,6.62L12.75,4H11.25Z" />
        </Canvas>-->

        <!--Конвертеры-->
        <Converters:ReceiptTimeConverter x:Key="ReceiptTimeConverter"/>
        <Converters:PacketTimeConverter x:Key="PacketTimeConverter" />

        <!--Стили-->
        <!--Стили таблицы данных-->
        <Style TargetType="DataGrid" x:Key="DataGridStyle">
            <Setter Property="AlternatingRowBackground" Value="OldLace" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
        </Style>
        <!--Стили заголовков в таблице данных-->
        <Style TargetType="DataGridColumnHeader" x:Key="DataGridHeaderStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5,3,5,3"/>
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Width" Value="auto" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <!--Стили строк в таблице данных-->
        <Style TargetType="DataGridRow" x:Key="DataGridRowStyle">
            <Setter Property="Background" Value="{Binding ReceiptTime, Converter={StaticResource ReceiptTimeConverter}}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="MediumSeaGreen"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!--Стили ячеек в таблице данных-->
        <Style TargetType="DataGridCell" x:Key="DataGridCellStyle">
            <Setter Property="Background">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource PacketTimeConverter}">
                        <Binding Path="ReceiptTime" />
                        <Binding Path="PacketTime" />
                    </MultiBinding>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel x:Name="Layout" LastChildFill="True">
        <!--ГЛАВНОЕ МЕНЮ-->
        <Menu x:Name="HeaderMenu" DockPanel.Dock="Top">
            <MenuItem Header="_Настройки" Height="25">
                <MenuItem.Command>
                    <cmd:TuningWindowCommand/>
                </MenuItem.Command>
            </MenuItem>
            <MenuItem Header="_Обновить" Height="25" Command="{Binding ManualUpdateData}"/>
            <MenuItem Header="_Остановить" Height="25" Command="{Binding StopUpdateData}" />
            <MenuItem Header="_Запустить" Height="25" Command="{Binding StartUpdateData}" />
            <MenuItem Header="_Закрыть"  Height="25" Command="{Binding CloseApplicationCommand}" />
        </Menu>

        <!--ПАНЕЛЬ КНОПОК-->
        <ToolBar x:Name="ToolBar" DockPanel.Dock="Top" Height="30" Width="auto" Background="#FFF0F0F0">
            <Button x:Name="ToolBarButtonTuning">
                <Image Source="../Resources/Icons/Tuning.ico" Height="19" Width="19"/>
                <!--<ContentControl Content="{StaticResource SettingsIcon}" />-->
                <Button.ToolTip>
                    <ToolTip>
                        Настройки.
                    </ToolTip>
                </Button.ToolTip>
                <Button.Command>
                    <cmd:TuningWindowCommand />
                </Button.Command>
                <Button.CommandParameter>
                    <Binding Path="AppTuning" />
                </Button.CommandParameter>
            </Button>
            <Button x:Name="ToolBarButtonReload" Command="{Binding ManualUpdateData}">
                <Image Source="../Resources/Icons/Reload.ico" Height="19" Width="19"/>
                <Button.ToolTip>
                    <ToolTip>
                        Обновить данные.
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button x:Name="ToolBarButtonStop" Command="{Binding StopUpdateData}">
                <Image Source="../Resources/Icons/Stop.ico" Height="19" Width="19"/>
                <Button.ToolTip>
                    <ToolTip>
                        Остановить обновление данных.
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button x:Name="ToolBarButtonPlay" Command="{Binding StartUpdateData}">
                <Image Source="../Resources/Icons/Play.ico" Height="19" Width="19"/>
                <Button.ToolTip>
                    <ToolTip>
                        Запустить обновление данных.
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Separator />
        </ToolBar>

        <!--ПАНЕЛЬ СОСТОЯНИЯ-->
        <StatusBar x:Name="FooterStatusBar" DockPanel.Dock="Bottom" Height="25" VerticalAlignment="Center">
            <StatusBarItem>
                <TextBlock Name="WindowSizeHeight" Text="{Binding ActualHeight, ElementName=GlobalIdentityMonitor, Mode=OneWay}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Name="WindowSizeWidth" Text="{Binding ActualWidth, ElementName=GlobalIdentityMonitor, Mode=OneWay}"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem >
                <TextBlock Name="ProgramVersion" Text="{Binding Path=ProgramVersion}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Name="DbName" Text="{Binding Path=DbName}"/>
            </StatusBarItem>
            <StatusBarItem>
                <Canvas Height="20" Width="20">
                    <Ellipse x:Name="CircleStatus" Width="10" Height="10" Canvas.Left="5" Canvas.Top="5">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding Path=Color}" />
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Name="NotifyText" Text="{Binding Path=DbStatusNotification}"/>
            </StatusBarItem>
        </StatusBar>

        <!--ПАНЕЛЬ ОСНОВНЫХ ВКЛАДОК-->
        <!--Таблица данных-->
        <DataGrid x:Name="SystemDataGrid"                                                    
                    ItemsSource="{Binding Path=ViewModelCollection}"
                    Style="{StaticResource DataGridStyle}"
                    RowStyle="{StaticResource DataGridRowStyle}"
                    SelectionUnit="CellOrRowHeader"
                    IsReadOnly="True"
                    LoadingRow="DataGrid_LoadingRow"
                    CanUserAddRows="False" CanUserDeleteRows="False"
                    CanUserSortColumns="True" CanUserReorderColumns="False" Grid.Row="0"
                    ClipboardCopyMode="ExcludeHeader">

            <!--Колонки-->
            <DataGrid.Columns>

                <DataGridTextColumn x:Name="SystemNameColumn"
                                    Header="Название&#13;системы"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    Binding="{Binding Path = Name}">
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="LastTimeColumn"
                                    Header="Время получения&#13;последнего пакета"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    Binding="{Binding Path = ReceiptTime, StringFormat={}{0:HH.mm.ss : dd.MM.yyyy}}">
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="PacketTimeColumn"
                                    Header="Время создания&#13;последнего пакета"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    Binding="{Binding Path = PacketTime, StringFormat={}{0:HH.mm.ss : dd.MM.yyyy}}">
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="ValueColumn"
                                    Header="Идентификатор"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    Binding="{Binding Path = Value}">
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="LastAddressColumn"
                                    Header="Последний&#13;IP адрес"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    Binding="{Binding Path = LastAddress}">
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="LastPortColumn"
                                    Header="Последний&#13;UDP порт"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    Binding="{Binding Path = LastPort}">
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="LastVersionColumn"
                                    Header="Версия"
                                    HeaderStyle="{StaticResource DataGridHeaderStyle}"
                                    Binding="{Binding Path = LastVersion}">
                </DataGridTextColumn>

            </DataGrid.Columns>

        </DataGrid>
    </DockPanel>

</Window>
