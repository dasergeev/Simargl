{
    "Tunings": {
        "Server": "127.0.0.1", //  Адрес сервера.
        "Port": 49001, //  Номер порта для подключения к серверу.
        "Identifier": "Testing", //  Идентификатор клиента.
        "Path": "C:\\RawData", //  Путь к файлам для передачи.
        "MinDuration": 30, //  Минимальная длительность хранения файла в секундах.
        "ConnectionTimeout": 10, //  Время ожидания установки соединения в секундах.
        "DataTimeout": 60 //  Время ожидания передачи данных в секундах.
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    }
}
