@* Маршрут страницы: /weather *@
@page "/weather"

@* Атрибут: включаем потоковый рендеринг (страница отображается частями по мере готовности данных) *@
@attribute [StreamRendering]

@* Заголовок вкладки браузера (title) — «Погода» *@
<PageTitle>Погода</PageTitle>

@* Заголовок страницы, видимый пользователю *@
<h1>Погода</h1>

@* Краткое описание: компонент показывает пример работы с данными *@
<p>Этот компонент демонстрирует отображение данных.</p>

@* Если массив прогнозов (forecasts) ещё не загружен *@
@if (forecasts == null)
{
    @* Сообщение пользователю, что данные ещё загружаются *@
    <p><em>Загрузка...</em></p>
}
@* Если данные уже загружены *@
else
{
    @* HTML-таблица для отображения прогноза погоды; применяются стили Bootstrap *@
    <table class="table">

        @* Заголовок таблицы *@
        <thead>

            @* Строка заголовков колонок *@
            <tr>

                @* Колонка с датой прогноза *@
                <th>Дата</th>

                @* Колонка с температурой в градусах Цельсия; aria-label для доступности *@
                <th aria-label="Температура в Цельсиях">Темп. (°C)</th>

                @* Колонка с температурой в Фаренгейтах *@
                <th aria-label="Температура в Фаренгейтах">Темп. (°F)</th>

                @* Колонка с текстовым описанием погоды (например, «Жарко») *@
                <th>Описание</th>
            </tr>
        </thead>

        @* Тело таблицы (заполняется строками прогноза) *@
        <tbody>

            @* Для каждого прогноза из массива forecasts рендерим строку *@
            @foreach (var forecast in forecasts)
            {
                @* Строка с данными по одному дню *@
                <tr>

                    @* Ячейка: дата прогноза в коротком формате *@
                    <td>@forecast.Date.ToShortDateString()</td>

                    @* Ячейка: температура в градусах Цельсия *@
                    <td>@forecast.TemperatureC</td>

                    @* Ячейка: температура в Фаренгейтах (вычисляется по формуле) *@
                    <td>@forecast.TemperatureF</td>

                    @* Ячейка: текстовое описание погоды *@
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

@* Блок C#-кода для компонента *@
@code {

    @* Массив для хранения прогнозов погоды; null пока данные не загружены *@
    private WeatherForecast[]? forecasts;

    @* Переопределяем асинхронный метод инициализации компонента *@
    protected override async Task OnInitializedAsync()
    {
        @* Симуляция асинхронной загрузки (пауза 500 мс) для демонстрации StreamRendering *@
        await Task.Delay(500);

        @* Определяем стартовую дату — сегодняшний день *@
        var startDate = DateOnly.FromDateTime(DateTime.Now);

        @* Возможные варианты описания погоды (на русском) *@
        var summaries = new[] { "Мороз", "Студено", "Прохладно", "Свежее", "Умеренно", "Тепло", "Мягко", "Жарко", "Душно", "Зной" };

        @* Генерируем 5 прогнозов на ближайшие дни *@
        forecasts = Enumerable.Range(1, 5).Select(index => new WeatherForecast
        {
            @* Дата прогноза = текущая дата + index дней *@
            Date = startDate.AddDays(index),

            @* Температура в Цельсиях — случайное число от -20 до +55 *@
            TemperatureC = Random.Shared.Next(-20, 55),

            @* Случайное описание погоды из массива summaries *@
            Summary = summaries[Random.Shared.Next(summaries.Length)]
        })
        @* Преобразуем результат в массив и сохраняем в forecasts *@
        .ToArray();
    }

    @* Вспомогательный класс, описывающий прогноз погоды *@
    private class WeatherForecast
    {
        @* Дата прогноза *@
        public DateOnly Date { get; set; }

        @* Температура в градусах Цельсия *@
        public int TemperatureC { get; set; }

        @* Текстовое описание погоды *@
        public string? Summary { get; set; }

        @* Температура в Фаренгейтах (вычисляется по формуле из Цельсия) *@
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}
